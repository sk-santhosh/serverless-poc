# Copy this file to values-secrets.yaml (already gitignored) and fill in
# real values. Never commit the copy. Install/upgrade with:
#
#   helm install operator . -f values-secrets.yaml
#
smtp:
  host: smtp.your-provider.com
  port: 587
  user: real-smtp-user
  pass: real-smtp-password
  fromEmail: welcome@yourdomain.com
