# Injected by the QueueWorker operator — never set these manually in a real
# deployment; they exist here only for local `node dist/index.js` testing.
REDIS_ADDRESS=localhost:6379
REDIS_STREAM=welcome-email-queue
REDIS_CONSUMER_GROUP=welcome-email-workers

# From the smtp-credentials Secret (envFrom). Point at a local maildev
# container for development — no auth required, no real emails sent.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=welcome@example.com
